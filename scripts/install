#!/bin/bash
# ==============================================================================
# hkup-cli Installation/Update Script
# ==============================================================================

set -euo pipefail

REPO="iton0/hkup-cli"
BINARY_ALIAS="hkup"

# --- Utilities ---

err()      { printf 'error: %s\n' "$1" >&2; exit 1; }
say()      { printf '%s\n' "$1"; }
say_warn() { printf 'warning: %s\n' "$1" >&2; }
ensure()   { if ! "$@"; then err "Command failed: $*"; fi; }
need_cmd() { command -v "$1" >/dev/null 2>&1 || err "Required dependency '$1' not found. Please install it."; }
check_cmd(){ command -v "$1" >/dev/null 2>&1; }

# Strip leading 'v'/'V' from version strings
version_strip() { printf '%s' "${1#[vV]}"; }

# --- Cleanup ---

_tmpdir=""
cleanup() {
    local _code=$?
    [ -n "$_tmpdir" ] && rm -rf "$_tmpdir"
    exit "$_code"
}
trap cleanup EXIT INT TERM HUP

# --- Platform Detection ---

detect_platform() {
    local _os _arch
    _os="$(uname -s)"
    _arch="$(uname -m)"

    case "$_arch" in
        x86_64|amd64)  _arch="amd64" ;;
        aarch64|arm64) _arch="aarch64" ;;
        *) err "Unsupported architecture: $_arch" ;;
    esac

    # Rosetta 2: uname -m reports x86_64 but machine is actually arm64
    if [ "$_os" = "Darwin" ] && [ "$_arch" = "amd64" ]; then
        if sysctl hw.optional.arm64 2>/dev/null | grep -q ': 1'; then
            _arch="aarch64"
        fi
    fi

    case "$_os" in
        Linux)               BINARY_NAME="hkup-linux-${_arch}" ;;
        Darwin)              BINARY_NAME="hkup-darwin-${_arch}" ;;
        CYGWIN*|MINGW*|MSYS*) BINARY_NAME="hkup.exe" ;;
        *) err "Unsupported OS: $_os. Only Linux, macOS, and Windows (Cygwin/MSYS/MinGW) are supported." ;;
    esac
}

# --- Install Path Detection ---

detect_install_path() {
    local _os
    _os="$(uname -s)"

    case "$_os" in
        Linux|Darwin)
            if [ "$(id -u)" = "0" ] && [ -n "${SUDO_USER:-}" ]; then
                local _original_home
                _original_home="$(getent passwd "$SUDO_USER" | cut -d: -f6 2>/dev/null || printf '/home/%s' "$SUDO_USER")"
                INSTALL_DIR="/usr/local/bin"
                CONFIG_DIR="${_original_home}/.config/${BINARY_ALIAS}"
                CONFIG_OWNER="$SUDO_USER"
            elif [ "$(id -u)" = "0" ]; then
                INSTALL_DIR="/usr/local/bin"
                CONFIG_DIR="${HOME}/.config/${BINARY_ALIAS}"
                CONFIG_OWNER="root"
            else
                INSTALL_DIR="${HOME}/.local/bin"
                CONFIG_DIR="${XDG_CONFIG_HOME:-${HOME}/.config}/${BINARY_ALIAS}"
                CONFIG_OWNER="$(id -un)"
            fi
            ;;
        CYGWIN*|MINGW*|MSYS*)
            INSTALL_DIR="${HOME}/bin"
            CONFIG_DIR="${LOCALAPPDATA:-${HOME}/AppData/Local}/${BINARY_ALIAS}"
            CONFIG_OWNER="$(id -un)"
            ;;
    esac

    INSTALL_PATH="${INSTALL_DIR}/${BINARY_ALIAS}"
    TEMPLATES_DIR="${CONFIG_DIR}/templates"
}

# --- Checksum Verification ---

verify_checksum() {
    local _file="$1" _expected_file="$2" _got _expected
    if check_cmd sha256sum; then
        _got="$(sha256sum "$_file" | awk '{print $1}')"
    elif check_cmd shasum; then
        _got="$(shasum -a 256 "$_file" | awk '{print $1}')"
    else
        say_warn "No sha256 tool found (sha256sum or shasum). Skipping integrity check."
        return 0
    fi
    _expected="$(cat "$_expected_file")"
    if [ "$_got" != "$_expected" ]; then
        err "Checksum mismatch for $(basename "$_file"):
  expected: $_expected
  got:      $_got"
    fi
    say "Checksum verified."
}

# --- Atomic Binary Install ---

install_binary() {
    local _src="$1" _dst="$2" _dst_dir _staging
    _dst_dir="$(dirname "$_dst")"
    ensure mkdir -p "$_dst_dir"
    # Stage inside dst dir so mv is atomic (same filesystem)
    _staging="$(mktemp "${_dst_dir}/.tmp.XXXXXXXXXX")"
    ensure cp "$_src" "$_staging"
    ensure chmod 755 "$_staging"
    ensure mv "$_staging" "$_dst"
}

# --- PATH Check ---

check_path() {
    case ":${PATH}:" in
        *":${INSTALL_DIR}:"*) return 0 ;;
        *) return 1 ;;
    esac
}

# --- Main ---

say "--- Checking Dependencies ---"
need_cmd curl
need_cmd grep
need_cmd sed
say "Dependencies OK."

# Detect platform and install paths
detect_platform
detect_install_path

say ""
say "--- Configuration ---"
say "Binary: ${BINARY_NAME}"
say "Install path: ${INSTALL_PATH}"
say "Config dir: ${CONFIG_DIR}"

# Progress: suppress in CI or non-interactive shells
if [ "${CI:-}" = "true" ] || [ ! -t 1 ]; then
    CURL_PROGRESS="--silent"
else
    CURL_PROGRESS="--progress-bar"
fi

# Create directories
ensure mkdir -p "$(dirname "$INSTALL_PATH")"
ensure mkdir -p "$CONFIG_DIR" "$TEMPLATES_DIR"
if [ "$(id -u)" = "0" ] && [ -n "${SUDO_USER:-}" ]; then
    chown -R "${CONFIG_OWNER}:${CONFIG_OWNER}" "$CONFIG_DIR" 2>/dev/null \
        || say_warn "Failed to set ownership of ${CONFIG_DIR} to ${CONFIG_OWNER}."
fi

# --- Version Check ---
say ""
say "--- Checking for Latest Version ---"

_api_response="$(curl --proto '=https' --tlsv1.2 -fsSL \
    "https://api.github.com/repos/${REPO}/releases/latest")"

if check_cmd jq; then
    FULL_RELEASE_TAG="$(printf '%s' "$_api_response" | jq -r .tag_name)"
else
    FULL_RELEASE_TAG="$(printf '%s' "$_api_response" \
        | grep '"tag_name":' | head -1 | sed -E 's/.*"([^"]+)".*/\1/')"
fi

if [ -z "$FULL_RELEASE_TAG" ] || [ "$FULL_RELEASE_TAG" = "null" ]; then
    err "Could not retrieve latest release tag from GitHub API. Check network connection."
fi

# Validate tag format before using in URLs
case "$FULL_RELEASE_TAG" in
    v[0-9]*.[0-9]*.[0-9]*) : ;;
    *) err "Unexpected tag format from GitHub API: '${FULL_RELEASE_TAG}'. Aborting." ;;
esac

LATEST_VERSION="$(version_strip "$FULL_RELEASE_TAG")"
say "Latest version available: ${LATEST_VERSION}"

# Check installed version
INSTALLED_VERSION=""
if [ -x "$INSTALL_PATH" ]; then
    _ver_output="$("$INSTALL_PATH" --version 2>/dev/null || true)"
    INSTALLED_VERSION="$(printf '%s' "$_ver_output" \
        | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)"
fi
if [ -z "$INSTALLED_VERSION" ] && check_cmd "$BINARY_ALIAS"; then
    _ver_output="$("$BINARY_ALIAS" --version 2>/dev/null || true)"
    INSTALLED_VERSION="$(printf '%s' "$_ver_output" \
        | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1 || true)"
fi

say "Currently installed: ${INSTALLED_VERSION:-none}"

if [ "${INSTALLED_VERSION:-}" = "$LATEST_VERSION" ]; then
    say ""
    say "Already up to date: ${BINARY_ALIAS} ${LATEST_VERSION}"
    exit 0
fi

# --- Download and Install ---
say ""

_tmpdir="$(mktemp -d)"
_bin_tmp="${_tmpdir}/${BINARY_NAME}"
_sum_tmp="${_bin_tmp}.sha256"

DOWNLOAD_BASE="https://github.com/${REPO}/releases/download/${FULL_RELEASE_TAG}"
BINARY_URL="${DOWNLOAD_BASE}/${BINARY_NAME}"
CHECKSUM_URL="${DOWNLOAD_BASE}/${BINARY_NAME}.sha256"

say "Downloading ${BINARY_NAME} ${LATEST_VERSION}..."
ensure curl --proto '=https' --tlsv1.2 -fL "$CURL_PROGRESS" \
    --output "$_bin_tmp" "$BINARY_URL"

# Download and verify checksum (graceful fallback if .sha256 not found)
if curl --proto '=https' --tlsv1.2 -fsSL --output "$_sum_tmp" "$CHECKSUM_URL" 2>/dev/null; then
    verify_checksum "$_bin_tmp" "$_sum_tmp"
else
    say_warn "Checksum file not found for this release. Skipping integrity check."
fi

say "Installing to ${INSTALL_PATH}..."
install_binary "$_bin_tmp" "$INSTALL_PATH"

say ""
if [ -n "${INSTALLED_VERSION:-}" ]; then
    say "${BINARY_ALIAS} updated: ${INSTALLED_VERSION} -> ${LATEST_VERSION}"
else
    say "${BINARY_ALIAS} ${LATEST_VERSION} installed."
fi

if ! check_path; then
    say ""
    say "Note: ${INSTALL_DIR} is not in your PATH."
    say "Add to your shell profile (~/.bashrc, ~/.zshrc, ~/.profile):"
    say "  export PATH=\"${INSTALL_DIR}:\$PATH\""
fi

exit 0
